---
import { readFile } from 'fs/promises';
import { existsSync } from 'fs';
import path from 'path';
import QRCode from 'qrcode';
import GalleryIsland from '../components/GalleryIsland';
import InteractiveBackground from '../components/InteractiveBackground';

// Load photos server-side for initial render
let initialPhotos: { url: string; guestName: string; caption: string }[] = [];
try {
  const dataPath = path.join(process.cwd(), 'data', 'photos.json');
  if (existsSync(dataPath)) {
    const raw = await readFile(dataPath, 'utf-8');
    const all = JSON.parse(raw);
    initialPhotos = all.filter((p: any) => p.approved !== false);
  }
} catch {}

// Build upload URL from request host
const host      = Astro.request.headers.get('host') || 'localhost:4321';
const protocol  = host.startsWith('localhost') ? 'http' : 'http'; // local network
const uploadUrl = `${protocol}://${host}/upload`;

// Generate QR as SVG string
const qrSvg = await QRCode.toString(uploadUrl, {
  type: 'svg',
  width: 400,
  margin: 2,
  color: { dark: '#1a0a2e', light: '#f5f0ff' },
  errorCorrectionLevel: 'H',
});
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>💍 Comparte tu foto — AstroGala QR</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #0d0618;
      font-family: 'Inter', sans-serif;
      color: white;
    }

    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
      min-height: 100vh;
      min-height: 100dvh;
    }
    @media (max-width: 600px) {
      body { padding: 40px 16px; justify-content: flex-start; overflow-y: auto; }
    }

    .hero-title { font-family: 'Cormorant Garamond', serif; }

    /* ── Card ─────────────────────────────────────────────────── */
    .card {
      background: rgba(15, 5, 30, 0.4);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 24px;
      padding: 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      width: 100%;
      max-width: min(380px, 92vw);
      box-shadow: 0 12px 40px rgba(0,0,0,0.4);
      z-index: 60;
      pointer-events: auto;
      max-height: 80vh;
      overflow-y: auto;
      scrollbar-width: none;
    }
    .card::-webkit-scrollbar { display: none; }

    @media (max-width: 600px) {
      .card {
        padding: 16px;
        gap: 10px;
        max-height: 75vh; /* Leave more space for browser UI */
      }
      .qr-wrap { padding: 8px !important; }
    }

    /* ── QR wrapper ───────────────────────────────────────────── */
    .qr-wrap {
      background: #f5f0ff;
      border-radius: 16px;
      padding: 12px;
      width: min(200px, 45vw);
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .qr-wrap svg { width: 100%; height: 100%; }

    /* ── Steps ────────────────────────────────────────────────── */
    .steps {
      display: flex;
      flex-direction: column;
      gap: 10px;
      width: 100%;
    }
    @media (max-width: 600px) {
      .steps { gap: 6px; }
      .step { padding: 8px 12px !important; }
      .step-text { font-size: 0.8rem !important; }
      .hero-title { font-size: 1.4rem !important; }
    }
    .step {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 14px;
    }
    .step-num {
      width: 28px; height: 28px;
      background: linear-gradient(135deg, #e11d48, #db2777);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.78rem; font-weight: 700; flex-shrink: 0;
    }
    .step-text { font-size: 0.88rem; color: rgba(255,255,255,0.75); line-height:1.3; }

    /* ── URL pill ─────────────────────────────────────────────── */
    .url-pill {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 99px;
      padding: 8px 18px;
      font-size: 0.82rem;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.01em;
      word-break: break-all;
      text-align: center;
    }

    /* ── Nav ──────────────────────────────────────────────────── */
    .nav {
      position: fixed;
      top: 16px;
      left: 16px;
      display: flex;
      gap: 8px;
      z-index: 100;
    }
    .nav a {
      padding: 6px 14px;
      border-radius: 99px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      font-size: 0.82rem;
      transition: all 0.2s;
    }
    .nav a:hover { color: white; background: rgba(255,255,255,0.12); }

    /* Print styles — clean white sheet */
    @media print {
      body { background: white; color: black; padding: 0; min-height: unset; }
      .nav { display: none; }
      .card {
        background: white;
        border: none;
        box-shadow: none;
        backdrop-filter: none;
        padding: 24px;
        max-width: 360px;
      }
      .qr-wrap { border: 2px solid #e5e7eb; box-shadow: none; }
      .step { background: #f9f9f9; border-color: #e5e7eb; }
      .step-text { color: #374151; }
      .url-pill { background: #f3f4f6; border-color: #e5e7eb; color: #6b7280; }
      .card .title { color: #1a0a2e !important; }
      .card .subtitle { color: #6b7280 !important; }
    }

    /* Totem (portrait screens ≥ 500px wide) */
    @media (orientation: portrait) and (min-width: 500px) {
      .card { max-width: 340px; }
      .qr-wrap { width: 220px; }
    }
  </style>
</head>
<body>
  <InteractiveBackground client:load />
  
  <div style="position:fixed; inset:0; z-index:0;">
    <GalleryIsland client:load initialPhotos={initialPhotos} isTotemMode={true} />
  </div>

  <div class="nav">
    <a href="/">← Volver</a>
  </div>

  <div class="card">
    <!-- Heading -->
    <div style="text-align:center;">
      <h1 class="hero-title title" style="font-size: 1.8rem; font-weight:600; letter-spacing:0.02em; line-height:1.1; color:white; margin:0;">
        Comparte tu foto
      </h1>
      <p class="subtitle" style="color:rgba(255,255,255,0.45); margin-top:4px; font-size:0.85rem; font-weight:300;">
        Escanea con tu cámara
      </p>
    </div>

    <!-- QR Code -->
    <div class="qr-wrap">
      <Fragment set:html={qrSvg} />
    </div>

    <!-- Steps -->
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <span class="step-text">Abre la cámara de tu celular y escanea el código</span>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <span class="step-text">Elige una foto de tu galería o tómala en el momento</span>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <span class="step-text">Escribe tu nombre y un mensaje para los novios 💌</span>
      </div>
    </div>

    <!-- URL -->
    <div class="url-pill">{uploadUrl}</div>

    <!-- Print button (hidden on print) -->
    <button
      onclick="window.print()"
      style="
        background: none; border: 1px solid rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.35); border-radius: 99px;
        padding: 8px 20px; font-size: 0.8rem; cursor: pointer;
        transition: all 0.2s;
      "
      onmouseover="this.style.color='rgba(255,255,255,0.7)'"
      onmouseout="this.style.color='rgba(255,255,255,0.35)'"
      class="no-print"
    >
      🖨️ Imprimir / Guardar PDF
    </button>
  </div>

</body>
</html>
