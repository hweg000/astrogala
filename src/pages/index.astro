---
import { readFile } from 'fs/promises';
import { existsSync } from 'fs';
import '../styles/global.css';
import path from 'path';
import GalleryIsland from '../components/GalleryIsland';
import InteractiveBackground from '../components/InteractiveBackground';

// Load photos server-side for initial render
let initialPhotos: { url: string; guestName: string; caption: string }[] = [];
try {
  const dataPath = path.join(process.cwd(), 'data', 'photos.json');
  if (existsSync(dataPath)) {
    const raw = await readFile(dataPath, 'utf-8');
    const all = JSON.parse(raw);
    initialPhotos = all.filter((p: any) => p.approved !== false);
  }
} catch {}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="description" content="Galería de fotos de la boda — comparte tus mejores momentos" />
  <title>💍 AstroGala — Galería de Boda</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { width: 100%; height: 100%; overflow: hidden; }
    body {
      background: #0d0618;
      font-family: 'Inter', sans-serif;
      color: white;
    }
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
    }
    .glass {
      background: rgba(255,255,255,0.06);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.12);
    }
    /* Ocultar botones cuando hay una foto abierta para máxima inmersión */
    body:has([data-enlarging="true"]) #upload-fab,
    body:has([data-enlarging="true"]) #view-toggle,
    body:has([data-enlarging="true"]) #person-filter {
      opacity: 0;
      pointer-events: none;
      transform: scale(0.8);
    }
  </style>
</head>
<body>
  <!-- Header overlay -->
  <div class="header-overlay">
    <div>
      <h1 class="hero-title">💍 AstroGala</h1>
      <p class="subtitle">Galería de la boda</p>
    </div>
    <div class="header-actions">
      <a href="/qr" class="btn-qr">QR</a>
      <span class="glass badge">
        <span id="count-num">{initialPhotos.length}</span> fotos
      </span>
    </div>
  </div>

  <InteractiveBackground client:load />

  <!-- Gallery (full screen) -->
  <div style="width:100vw;height:100vh;">
    <GalleryIsland client:load initialPhotos={initialPhotos} />
  </div>

  <style is:global>
    .header-overlay {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50; 
      padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; 
      pointer-events: none;
    }
    .header-overlay > * { pointer-events: auto; }
    .header-overlay h1 { font-size: clamp(1.2rem, 4vw, 2rem); font-weight: 600; line-height: 1.1; text-shadow: 0 2px 20px rgba(0,0,0,0.8); }
    .header-overlay .subtitle { font-size: 0.75rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 2px; }
    .header-actions { display: flex; align-items: center; gap: 8px; }
    .btn-qr { 
      padding: 6px 14px; border-radius: 99px; background: rgba(255,255,255,0.06); 
      border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.6); 
      text-decoration: none; font-size: 0.8rem; transition: all 0.2s; 
    }
    .btn-qr:hover { color: white; background: rgba(255,255,255,0.12); }
    .badge { padding: 6px 14px; border-radius: 99px; font-size: 0.8rem; color: rgba(255,255,255,0.7); }
    
    /* Responsive adjustment for extra small screens */
    @media (max-width: 380px) {
      .header-overlay .subtitle { display: none; }
      .header-overlay { padding: 12px 14px; }
    }
  </style>
</body>
</html>
